<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link href="css/output.css" rel="stylesheet" />
    <link href="~/css/app.css" rel="stylesheet" />
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["ProductManagement_.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet />

    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: ui-sans-serif, system-ui, sans-serif;
        }

        ::-webkit-scrollbar {
            width: 5px;
        }

        ::-webkit-scrollbar-track {
            background: #04083A;
        }

        ::-webkit-scrollbar-thumb {
            background: #1E2A78;
            border-radius: 4px;
        }

            ::-webkit-scrollbar-thumb:hover {
                background: #53CBF3;
            }

        input:-webkit-autofill,
        input:-webkit-autofill:hover,
        input:-webkit-autofill:focus {
            -webkit-text-fill-color: white;
            -webkit-box-shadow: 0 0 0px 1000px #07104A inset;
            transition: background-color 5000s ease-in-out 0s;
        }

        .nav-link-active {
            background: rgba(83,203,243,0.15) !important;
            color: #53CBF3 !important;
            border-left: 3px solid #53CBF3 !important;
        }

        select option {
            background: #0A0F3C;
            color: white;
        }
    </style>
</head>

<body>
    
    <Routes @rendermode="new InteractiveServerRenderMode(prerender: false)" />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>
