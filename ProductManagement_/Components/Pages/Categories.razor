@* Components/Pages/Categories.razor *@
@page "/categories"
@rendermode InteractiveServer
@attribute [Authorize]
@inject ICategoryService CategoryService


<PageTitle>Categories — Product Management</PageTitle>

<div class="flex items-center justify-between mb-5">
    <p class="text-2xl font-bold" style="color:#9ca3af;">Manage product categories</p>
    <AuthorizeView Roles="Admin">
        <Authorized Context="c">
            <button @onclick="OpenAdd"
                    class="flex items-center gap-2 px-4 py-2 rounded-md text-xs font-bold hover:opacity-90"
                    style="background:#53CBF3;color:#04083A;border:none;cursor:pointer;">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                </svg>
                Add Category
            </button>
        </Authorized>
    </AuthorizeView>
</div>

<!-- Search -->
<div class="relative mb-5" style="max-width:300px;">
    <span class="absolute inset-y-0 left-3 flex items-center pointer-events-none" style="color:#53CBF3;">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0"/>
        </svg>
    </span>
    <input type="text"
           value="@_search"
           @oninput="e => { _search = e.Value?.ToString() ?? string.Empty; Filter(); }"
           placeholder="Search categories..."
           class="w-full text-sm text-white rounded-md"
           style="background:#0A0F3C;border:1px solid #1E2A78;padding:8px 12px 8px 32px;outline:none;" />
</div>

<!-- Table -->
<div class="rounded-lg border overflow-hidden" style="background:#0A0F3C;border-color:#1E2A78;">
    @if (_loading)
    {
        <div class="flex justify-center py-16">
            <div class="animate-spin rounded-full h-8 w-8 border-b-2" style="border-color:#53CBF3;"></div>
        </div>
    }
    else
    {
        <table class="w-full text-xs">
            <thead>
                <tr style="background:#07104A;">
                    <th class="text-left px-4 py-3 font-semibold uppercase tracking-wider" style="color:#53CBF3;">#</th>
                    <th class="text-left px-4 py-3 font-semibold uppercase tracking-wider" style="color:#53CBF3;">Name</th>
                    <th class="text-left px-4 py-3 font-semibold uppercase tracking-wider" style="color:#53CBF3;">Description</th>
                    <th class="text-left px-4 py-3 font-semibold uppercase tracking-wider" style="color:#53CBF3;">Status</th>
                    <th class="text-left px-4 py-3 font-semibold uppercase tracking-wider" style="color:#53CBF3;">Created</th>
                    <AuthorizeView Roles="Admin">
                        <Authorized Context="h"><th class="text-left px-4 py-3 font-semibold uppercase tracking-wider" style="color:#53CBF3;">Actions</th></Authorized>
                    </AuthorizeView>
                </tr>
            </thead>
            <tbody>
                @if (!_filtered.Any())
                {
                    <tr><td colspan="6" class="px-5 py-10 text-center" style="color:#6b7280;">No categories found.</td></tr>
                }
                else
                {
                    int i = 1;
                    @foreach (var cat in _filtered)
                    {
                        <tr class="border-t transition-colors hover:bg-white/[0.03]" style="border-color:#1E2A78;">
                            <td class="px-4 py-3" style="color:#4b5563;">@(i++)</td>
                            <td class="px-4 py-3 text-white font-medium">@cat.Name</td>
                            <td class="px-4 py-3" style="color:#9ca3af;">@(cat.Description ?? "—")</td>
                            <td class="px-4 py-3">
                                <span class="px-2 py-0.5 rounded-full font-semibold"
                                      style="@(cat.IsActive ? "background:rgba(52,211,153,0.12);color:#34d399;" : "background:rgba(239,68,68,0.12);color:#f87171;")">
                                    @(cat.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td class="px-4 py-3" style="color:#4b5563;">@cat.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <AuthorizeView Roles="Admin">
                                <Authorized Context="r">
                                    <td class="px-4 py-3">
                                        <div class="flex gap-2">
                                            <button @onclick="() => OpenEdit(cat)"
                                                    class="px-2 py-1 rounded text-xs font-semibold border hover:bg-white/10"
                                                    style="border-color:#53CBF3;color:#53CBF3;background:transparent;cursor:pointer;">Edit</button>
                                            <button @onclick="() => AskDelete(cat.Id, cat.Name)"
                                                    class="px-2 py-1 rounded text-xs font-semibold border hover:bg-red-900/20"
                                                    style="border-color:#f87171;color:#f87171;background:transparent;cursor:pointer;">Delete</button>
                                        </div>
                                    </td>
                                </Authorized>
                            </AuthorizeView>
                        </tr>
                    }
                }
            </tbody>
        </table>
        <div class="px-4 py-2 border-t text-xs" style="border-color:#1E2A78;color:#4b5563;">
            @_filtered.Count of @_all.Count categories
        </div>
    }
</div>

<!-- Modal -->
@if (_showModal)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4" style="background:rgba(0,0,0,0.75);">
        <div class="w-full rounded-lg border shadow-2xl" style="max-width:420px;background:#0A0F3C;border-color:#1E2A78;">
            <div class="flex items-center justify-between px-5 py-4 border-b" style="border-color:#1E2A78;">
                <h3 class="text-white font-semibold text-sm">@(_isEditing ? "Edit Category" : "Add Category")</h3>
                <button @onclick="CloseModal" style="color:#9ca3af;background:none;border:none;cursor:pointer;font-size:16px;">✕</button>
            </div>
            <EditForm Model="_form" OnValidSubmit="Save" class="p-5">
                <DataAnnotationsValidator />
                @if (!string.IsNullOrEmpty(_err))
                {
                    <div class="mb-4 p-3 rounded-md text-xs" style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#f87171;">@_err</div>
                }
                <div class="space-y-4">
                    <div>
                        <label class="block text-xs font-medium mb-1" style="color:#9ca3af;">Name *</label>
                        <InputText @bind-Value="_form.Name" placeholder="Category name"
                                   class="w-full text-sm text-white rounded-md"
                                   style="background:#07104A;border:1px solid #1E2A78;padding:8px 10px;outline:none;" />
                        <ValidationMessage For="@(() => _form.Name)" class="text-xs mt-1" style="color:#f87171;" />
                    </div>
                    <div>
                        <label class="block text-xs font-medium mb-1" style="color:#9ca3af;">Description</label>
                        <InputTextArea @bind-Value="_form.Description" rows="3" placeholder="Optional description"
                                       class="w-full text-sm text-white rounded-md resize-none"
                                       style="background:#07104A;border:1px solid #1E2A78;padding:8px 10px;outline:none;" />
                    </div>
                    <div class="flex items-center gap-2">
                        <InputCheckbox @bind-Value="_form.IsActive" class="w-4 h-4" />
                        <label class="text-xs" style="color:#9ca3af;">Active</label>
                    </div>
                    <div class="flex gap-3">
                        <button type="button" @onclick="CloseModal"
                                class="flex-1 py-2 rounded-md text-xs border"
                                style="border-color:#1E2A78;color:#9ca3af;background:transparent;cursor:pointer;">Cancel</button>
                        <button type="submit" disabled="@_saving"
                                class="flex-1 py-2 rounded-md text-xs font-bold disabled:opacity-50"
                                style="background:#53CBF3;color:#04083A;border:none;cursor:pointer;">
                            @(_saving ? "Saving..." : (_isEditing ? "Update" : "Add"))
                        </button>
                    </div>
                </div>
            </EditForm>
        </div>
    </div>
}

<ConfirmModal IsVisible="_showDelete"
              Title="Delete Category"
              Message="@($"Delete \"{_deleteName}\"?")"
              OnConfirm="ConfirmDelete"
              OnCancel="@(() => _showDelete = false)" />

@code {
    private List<Category> _all = new(), _filtered = new();
    private bool _loading = true, _showModal = false, _isEditing = false, _saving = false, _showDelete = false;
    private int _editId, _deleteId;
    private string _deleteName = "", _search = "", _err = "";
    private CatForm _form = new();

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        _loading = true;
        try { _all = await CategoryService.GetAllAsync(); Filter(); }
        finally { _loading = false; }
    }

    private void Filter() =>
        _filtered = _all.Where(c => string.IsNullOrEmpty(_search) ||
            c.Name.Contains(_search, StringComparison.OrdinalIgnoreCase)).ToList();

    private void OpenAdd()  { _form = new CatForm { IsActive = true }; _isEditing = false; _err = ""; _showModal = true; }
    private void OpenEdit(Category c) { _editId = c.Id; _form = new CatForm { Name = c.Name, Description = c.Description, IsActive = c.IsActive }; _isEditing = true; _err = ""; _showModal = true; }
    private void CloseModal() { _showModal = false; _err = ""; }

    private async Task Save()
    {
        _saving = true;
        try
        {
            if (_isEditing) { var e = await CategoryService.GetByIdAsync(_editId); if (e is not null) { e.Name = _form.Name; e.Description = _form.Description; e.IsActive = _form.IsActive; await CategoryService.UpdateAsync(e); } }
            else { await CategoryService.AddAsync(new Category { Name = _form.Name, Description = _form.Description, IsActive = _form.IsActive }); }
            CloseModal(); await Load();
        }
        catch (Exception ex) { _err = ex.Message; }
        finally { _saving = false; }
    }

    private void AskDelete(int id, string name) { _deleteId = id; _deleteName = name; _showDelete = true; }
    private async Task ConfirmDelete()
    {
        try { await CategoryService.DeleteAsync(_deleteId); await Load(); }
        catch { }
        finally { _showDelete = false; }
    }

    public class CatForm
    {
        [Required(ErrorMessage = "Name is required")]
        public string  Name        { get; set; } = "";
        public string? Description { get; set; }
        public bool    IsActive    { get; set; } = true;
    }
}
